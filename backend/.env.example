# ==================== 阿里云凭据（OSS 用）====================
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ==================== LLM 配置 ====================
DASHSCOPE_API_KEY=
LLM_MODEL=qwen-plus
LLM_CLEAN_MODEL=qwen-turbo
LANGSMITH_TRACING=

# ==================== Milvus 向量数据库 ====================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus

# ==================== PostgreSQL 业务数据库 ====================
PG_HOST=localhost
PG_PORT=5432
PG_DB=knowledge_db
PG_USER=kbuser
PG_PASSWORD=kbpass

# ==================== Embedding 配置 ====================
# 调用 DashScope 生成向量，需要 DASHSCOPE_API_KEY
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1536
# 每批最多发送的文本数量（DashScope 单次最多 25 条）
EMBEDDING_BATCH_SIZE=20

# ==================== 向量检索配置 ====================
VECTOR_TOP_K=10
VECTOR_SCORE_THRESHOLD=0

# ==================== 切片配置 ====================
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==================== OSS 配置 ====================
OSS_BUCKET=
OSS_REGION=cn-shanghai
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# ==================== API 配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
SSL_VERIFY=false
