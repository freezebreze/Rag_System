# ==================== 对象存储配置 ====================
# aliyun 或 r2
OBJECT_STORAGE_PROVIDER=aliyun

# 阿里云 OSS 凭据（OBJECT_STORAGE_PROVIDER=aliyun 时使用）
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=cn-shanghai
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# Cloudflare R2 凭据（OBJECT_STORAGE_PROVIDER=r2 时使用）
# R2_ENDPOINT 格式通常为：https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto

# ==================== LLM 配置 ====================
DASHSCOPE_API_KEY=
LLM_MODEL=qwen-plus
LLM_CLEAN_MODEL=qwen-turbo
LANGSMITH_TRACING=

# ==================== Milvus 向量数据库 ====================
MILVUS_HOST=
MILVUS_PORT=
MILVUS_USER=
MILVUS_PASSWORD=
# ==================== PostgreSQL 业务数据库 ====================
PG_HOST=
PG_PORT=
PG_DB=
PG_USER=
PG_PASSWORD=

# ==================== Embedding 配置 ====================
# 调用 DashScope 生成向量，需要 DASHSCOPE_API_KEY
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1536
# 每批最多发送的文本数量（DashScope 单次最多 25 条）
EMBEDDING_BATCH_SIZE=20

# ==================== 向量检索配置 ====================
VECTOR_TOP_K=10
VECTOR_SCORE_THRESHOLD=0

# ==================== 切片配置 ====================
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==================== MinIO 配置（docker-compose 用）====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==================== PostgreSQL 配置（docker-compose 用）====================
POSTGRES_DB=knowledge_db
POSTGRES_USER=kbuser
POSTGRES_PASSWORD=kbpass

# ==================== API 配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
SSL_VERIFY=false
